# =============================================================================
# CT.gov Search Strategies - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# AACT Database Connection (Required)
# -----------------------------------------------------------------------------
# AACT (Aggregate Analysis of ClinicalTrials.gov) is a PostgreSQL database
# containing all public data from ClinicalTrials.gov
#
# To obtain credentials:
# 1. Visit https://aact.ctti-clinicaltrials.org/
# 2. Click "Create Account" and register for free
# 3. After registration, you'll receive your username and password
# 4. Note: Password resets may be required periodically
#
# Documentation: https://aact.ctti-clinicaltrials.org/learn_more

AACT_HOST=aact-db.ctti-clinicaltrials.org
AACT_PORT=5432
AACT_DATABASE=aact
AACT_USER=your_username
AACT_PASSWORD=your_password

# -----------------------------------------------------------------------------
# Optional Settings
# -----------------------------------------------------------------------------
# These have sensible defaults but can be customized as needed

# Rate limit for ClinicalTrials.gov API requests (seconds between requests)
# Default: 0.3 seconds (approximately 3 requests per second)
# Increase this value if you encounter rate limiting errors
CTGOV_RATE_LIMIT=0.3

# Request timeout in seconds
# Default: 30 seconds
# Increase for slow connections or large queries
CTGOV_TIMEOUT=30

# Maximum number of retry attempts for failed requests
# Default: 3 retries with exponential backoff
CTGOV_MAX_RETRIES=3
